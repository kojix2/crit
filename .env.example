# Crit Environment Configuration
# Copy this file to .env and customize as needed

# Admin username
CRIT_USER=change-me

# Admin password
# Make sure to change this in production environments
CRIT_PASS=change-me-strong-password

# Repository storage directory
# When using Docker, this path is mounted as a volume
CRIT_REPO_ROOT=/data/git

# Enable Git Smart HTTP endpoints
# Set to false for SSH-first operation (recommended for single-user deployments)
CRIT_GIT_HTTP_ENABLED=true

# Server port
PORT=3000

# Log level for application logging (e.g., DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Kemal environment (use 'production' for deployment, 'development' for local testing)
KEMAL_ENV=development
